# iCognition Backend Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL database URL
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://app:2214@localhost:5432/icog_dev_db

# =============================================================================
# FIREBASE AUTHENTICATION (OPTIONAL)
# =============================================================================
# Set DISABLE_AUTH=true to skip Firebase authentication for development
DISABLE_AUTH=true

# Firebase Project Configuration
# Get these values from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com

# =============================================================================
# GOOGLE AI CONFIGURATION
# =============================================================================
# Google AI API Key for Gemini AI services
# Get this from Google AI Studio: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-api-key

# =============================================================================
# GOOGLE CLOUD STORAGE (OPTIONAL)
# =============================================================================
# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# Google Cloud Storage Bucket Name
GOOGLE_CLOUD_STORAGE_BUCKET=your-storage-bucket

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# CORS allowed origins (JSON array format)
BACKEND_CORS_ORIGINS=["http://localhost:8080", "http://127.0.0.1:8080", "http://localhost:3000"]

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60

# Maximum failed authentication attempts before IP lockout
MAX_FAILED_ATTEMPTS=5

# IP lockout duration in minutes
LOCKOUT_DURATION_MINUTES=15

# Enable CORS security features
ENABLE_CORS_SECURITY=true

# Enable security headers
ENABLE_SECURITY_HEADERS=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Enable debug mode (shows detailed error messages)
DEBUG=false

# Enable SQL query logging
SQL_DEBUG=false

# Test database URL (for running tests)
TEST_DATABASE_URL=postgresql://app:2214@localhost:5432/icog_test_db

# =============================================================================
# EXTERNAL SERVICES (OPTIONAL)
# =============================================================================
# Hugging Face API Token (for additional AI models)
HF_API_TOKEN=your-huggingface-token

# OpenAI API Key (if using OpenAI services)
OPENAI_API_KEY=your-openai-api-key

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================
# Environment (development, staging, production)
ENVIRONMENT=development

# Server host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Server port
PORT=8000

# =============================================================================
# MONITORING & ANALYTICS (OPTIONAL)
# =============================================================================
# Sentry DSN for error tracking
SENTRY_DSN=your-sentry-dsn

# Google Analytics tracking ID
GA_TRACKING_ID=your-ga-tracking-id

# =============================================================================
# NOTES
# =============================================================================
# 1. For development, set DISABLE_AUTH=true to skip Firebase setup
# 2. The database will be created automatically by Docker Compose
# 3. Google AI API key is required for content analysis features
# 4. Firebase configuration is only needed if DISABLE_AUTH=false
# 5. All optional services can be left empty if not used
# 6. Make sure to keep your .env file secure and never commit it to version control
